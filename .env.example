# ── LLM (Required for real AI responses) ────────────────────────
# Get free at: https://console.groq.com  (takes 60 seconds)
GROQ_API_KEY=your_groq_api_key_here

# ── Weather (Optional — free tier works fine) ───────────────────
# Get free at: https://openweathermap.org/api  (free tier: 60 calls/min)
OPENWEATHER_API_KEY=your_openweather_key_here

# ── Demo Mode ───────────────────────────────────────────────────
# Set to "true" to run with zero API keys (uses realistic mock data)
DEMO_MODE=false

# ── App Settings ────────────────────────────────────────────────
GROQ_MODEL=llama-3.1-8b-instant
CAFE_NAME=Suto Café
CAFE_LOCATION=Siliguri, West Bengal
